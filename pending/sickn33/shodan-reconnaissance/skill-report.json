    "faq": [
      {
        "question": "Is Shodan legal to use?",
        "answer": "Shodan is a legal security research tool. However, using it to scan or target systems without authorization may violate laws. Always obtain written permission before investigating specific targets."
      },
      {
        "question": "Do I need a paid Shodan account?",
        "answer": "A free account provides limited credits. Paid plans offer more queries and scan credits. Basic searches without filters are free."
      },
      {
        "question": "Can this skill help me hack systems?",
        "answer": "No. This skill provides reconnaissance methodology for authorized security testing. Unauthorized access to computer systems is illegal."
      },
      {
        "question": "How accurate is Shodan data?",
        "answer": "Shodan data may be days or weeks old. On-demand scans provide current data. Always verify critical findings with direct testing."
      },
      {
        "question": "What are Shodan credits?",
        "answer": "Credits are consumed for filtered searches, downloads, and on-demand scans. Basic searches without filters are free. Check your balance with 'shodan info'."
      },
      {
        "question": "Can I scan private IP ranges?",
        "answer": "Shodan crawls public internet. Private IP ranges (RFC 1918) like 192.168.x.x are placeholders in examples. Only public IPs can be scanned."
      }
    ]
