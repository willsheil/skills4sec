  "content": {
    "user_title": "Create PowerPoint Presentations",
    "value_statement": "Claude can create, edit, and analyze PowerPoint presentations by converting HTML to PPTX, manipulating raw XML structures, and extracting content from existing files.",
    "seo_keywords": [
      "Claude PowerPoint",
      "Claude Codex pptx",
      "Claude Code presentation",
      "create pptx with AI",
      "PowerPoint automation",
      "HTML to PowerPoint",
      "presentation creation AI",
      "pptx manipulation",
      "slide generation",
      "AI presentation tool"
    ],
    "actual_capabilities": [
      "Create new PowerPoint presentations from scratch using HTML to PPTX conversion",
      "Extract and analyze text content from existing presentations",
      "Access and modify raw XML structure for advanced features like comments, speaker notes, and layouts",
      "Apply design templates, color palettes, and typography from example presentations",
      "Work with slide layouts, themes, and master slides"
    ],
    "limitations": [
      "Cannot directly edit PowerPoint files without unpacking to XML first",
      "Requires external tools like markitdown or pandoc for some conversions",
      "Complex formatting may require direct XML manipulation",
      "No built-in charting or advanced graphics creation"
    ],
    "use_cases": [
      {
        "title": "Generate Presentation from Outline",
        "description": "Create a complete PowerPoint presentation from a text outline or content brief",
        "target_user": "Business professionals needing quick slide decks"
      },
      {
        "title": "Extract Content from Existing Slides",
        "description": "Read and extract text, notes, and comments from existing PPTX files for analysis or repurposing",
        "target_user": "Researchers and content analysts"
      },
      {
        "title": "Apply Design Template",
        "description": "Analyze an example presentation and apply its color scheme, fonts, and layout patterns to new slides",
        "target_user": "Designers maintaining brand consistency"
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple Slide Creation",
        "prompt": "Create a PowerPoint presentation with these slides: [list slide titles and content]. Use a professional design.",
        "scenario": "Quick presentation generation from outline"
      },
      {
        "title": "Extract Text Content",
        "prompt": "Extract all text content from the attached presentation file. List each slide's content separately.",
        "scenario": "Reading existing presentation content"
      },
      {
        "title": "Apply Brand Design",
        "prompt": "Analyze the design elements in [example.pptx] including colors, fonts, and layout patterns. Then create new slides about [topic] using the same design language.",
        "scenario": "Brand-consistent presentation creation"
      },
      {
        "title": "Add Speaker Notes",
        "prompt": "Add speaker notes to slides 2-5 in [presentation.pptx] with talking points about [content].",
        "scenario": "Enhancing presentations with notes"
      }
    ],
    "output_examples": [
      {
        "input": "Create a 5-slide presentation about Q4 results with bullet points",
        "output": [
          "Created presentation.pptx with 5 slides",
          "Slide 1: Title - Q4 Results Overview",
          "Slide 2: Key Metrics with charts",
          "Slide 3: Revenue Analysis",
          "Slide 4: Challenges and Solutions",
          "Slide 5: Next Steps and Action Items"
        ]
      },
      {
        "input": "What content is in slide 3 of this presentation?",
        "output": [
          "Slide 3: Customer Feedback Summary",
          "- Overall satisfaction: 4.2/5",
          "- Top mentioned features: speed, reliability",
          "- Areas for improvement: documentation"
        ]
      }
    ],
    "best_practices": [
      "Analyze existing presentations for design patterns before creating new ones",
      "Use HTML-to-PPTX conversion for precise positioning and layout control",
      "Extract XML content for complex features like comments and speaker notes",
      "Apply consistent color palettes and typography throughout presentations"
    ],
    "anti_patterns": [
      "Attempting to directly edit PPTX files without unpacking to XML first",
      "Ignoring the design principles and color palette guidelines",
      "Using non-web-safe fonts that may not render on all systems",
      "Overloading slides with too much content"
    ],
    "faq": [
      {
        "question": "Can Claude edit existing PowerPoint files?",
        "answer": "Claude can modify existing PPTX files by unpacking them, editing the XML, and repacking. This is needed because PPTX files are ZIP archives containing XML."
      },
      {
        "question": "What tools does this skill use?",
        "answer": "The skill uses Python libraries like markitdown for text extraction and custom scripts for XML manipulation. It also leverages pandoc and unoconv for format conversions."
      },
      {
        "question": "Can I create charts in PowerPoint?",
        "answer": "The skill does not have built-in chart creation. For charts, you would need to create them manually in PowerPoint or use a separate charting tool."
      },
      {
        "question": "How do I add speaker notes?",
        "answer": "Speaker notes are stored in XML files within the PPTX structure. You need to unpack the presentation, add content to the notesSlide XML files, and repack the archive."
      },
      {
        "question": "What design constraints should I follow?",
        "answer": "Use web-safe fonts (Arial, Helvetica, Times New Roman, etc.), ensure good color contrast, maintain visual hierarchy, and be consistent with spacing and patterns."
      },
      {
        "question": "Can this skill work with Google Slides?",
        "answer": "This skill is specifically for PPTX (Microsoft PowerPoint) files. Google Slides would require a different approach using the Google Slides API."
      }
    ]
  },
