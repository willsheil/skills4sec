  "content": {
    "user_title": "Automate SendGrid Email Campaigns",
    "value_statement": "SendGrid requires complex API workflows for marketing campaigns, contact management, and analytics. This skill provides ready-to-use sequences for common SendGrid operations so you can automate email campaigns without researching API documentation.",
    "seo_keywords": [
      "SendGrid",
      "email automation",
      "marketing email",
      "email campaign",
      "contact management",
      "Claude",
      "Codex",
      "Claude Code",
      "MCP"
    ],
    "actual_capabilities": [
      "Create and send marketing email campaigns (Single Sends) to contact lists",
      "Manage contact lists: create, update, search, and delete contacts",
      "Set up and verify sender identities for sending emails",
      "Retrieve email statistics and filter message activity",
      "Manage suppression groups and unsubscribe settings",
      "Handle async contact operations with proper wait times"
    ],
    "limitations": [
      "Requires Rube MCP server with SendGrid toolkit to be configured",
      "Requires active SendGrid API key authentication",
      "Contact import operations are async and require 10-30 second wait times",
      "Some features require paid SendGrid add-ons (e.g., 30 Days Email Activity History)"
    ],
    "use_cases": [
      {
        "title": "Marketing Team Sends Newsletter Campaign",
        "description": "A marketing team member wants to send a monthly newsletter to their subscriber list. They need to create a campaign, select the recipient list, and verify the sender is authenticated.",
        "target_user": "Marketing professionals"
      },
      {
        "title": "Developer Automates Contact Sync",
        "description": "A developer building a CRM needs to sync contacts to SendGrid for email outreach. They need to create lists, add contacts in bulk, and handle async processing correctly.",
        "target_user": "Developers building email workflows"
      },
