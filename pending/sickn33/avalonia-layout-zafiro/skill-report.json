  "content": {
    "user_title": "Build clean Avalonia UI layouts with Zafiro",
    "value_statement": "Create maintainable Avalonia applications using semantic containers and shared styles. Reduce XAML redundancy with Zafiro.Avalonia components and best practices.",
    "seo_keywords": [
      "Avalonia UI",
      "Zafiro Avalonia",
      "XAML layout",
      "Claude Code skill",
      "Codex UI design",
      ".NET desktop",
      "Avalonia components",
      "UI layout guide"
    ],
    "actual_capabilities": [
      "Guide semantic container usage with HeaderedContainer, EdgePanel, and Card components",
      "Apply shared styles and DynamicResource for consistent theming",
      "Implement IconExtension markup for FontAwesome icons",
      "Use Xaml.Interaction.Behaviors for UI logic without code-behind",
      "Create generic reusable components to reduce XAML nesting",
      "Organize theme resources across Colors, Styles, and App axaml files"
    ],
    "limitations": [
      "Documentation only - does not execute or generate actual XAML code",
      "Focused on Zafiro.Avalonia library patterns, not raw Avalonia",
      "Requires existing Avalonia project setup",
      "Does not cover custom control development"
    ],
    "use_cases": [
      {
        "title": "Desktop App Developer",
        "description": "Refactor existing Avalonia views to use semantic containers and shared styles for cleaner, maintainable XAML.",
        "target_user": ".NET desktop developers building Avalonia applications"
      },
      {
        "title": "UI Architect",
        "description": "Establish consistent UI patterns across a large Avalonia codebase using Zafiro components and theme organization.",
        "target_user": "Technical leads designing Avalonia application architecture"
      },
      {
        "title": "Cross-Platform Developer",
        "description": "Learn modern Avalonia layout techniques that work across Windows, macOS, and Linux platforms.",
        "target_user": "Developers new to Avalonia from WPF or other XAML frameworks"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Container Selection",
        "prompt": "I need to create a settings section with a header and content. Which Zafiro container should I use and how?",
        "scenario": "Beginner learning semantic containers"
      },
      {
        "title": "Icon Integration",
        "prompt": "Show me how to add FontAwesome icons to buttons and headers using IconExtension with consistent styling.",
        "scenario": "Adding visual elements to UI components"
      },
      {
        "title": "Style Extraction",
        "prompt": "I have repeated property settings across multiple HeaderedContainer elements. Help me extract these into a shared style using Classes.",
        "scenario": "Refactoring redundant XAML properties"
      },
      {
        "title": "Behavior Implementation",
        "prompt": "I need to handle focus management for a TextBox without using code-behind. Show me how to implement this with Interaction.Behaviors.",
        "scenario": "Advanced UI logic encapsulation"
      }
    ],
    "output_examples": [
      {
        "input": "Create a wallet balance display with icon, label, and value",
        "output": "Use EdgePanel with StartContent for the wallet icon, Content for the label, and EndContent for the balance value. Apply IconOptions.Size and IconOptions.Fill for consistent icon styling."
      },
      {
        "input": "How do I avoid repeating border and color settings?",
        "output": "Define a Style in Containers.axaml with selector 'HeaderedContainer.BlueSection', set CornerRadius, BorderThickness, BorderBrush, and Background using DynamicResource. Apply with Classes='BlueSection'."
      }
    ],
    "best_practices": [
      "Use DynamicResource for colors and brushes to support theme switching",
      "Flatten layouts with EdgePanel instead of nested Grid and StackPanel structures",
      "Extract repeated layouts into generic UserControl components for reusability"
    ],
    "anti_patterns": [
      "Using hardcoded colors or sizes directly in view XAML instead of resources",
      "Creating deep nesting with multiple Grid and StackPanel layers",
      "Using IValueConverter for simple logic that belongs in the ViewModel"
    ],
    "faq": [
      {
        "question": "What is Zafiro.Avalonia?",
        "answer": "Zafiro.Avalonia is a library providing enhanced UI components for Avalonia, including semantic containers like HeaderedContainer and EdgePanel, plus icon management via IconExtension."
      },
      {
        "question": "How do I add Zafiro.Avalonia to my project?",
        "answer": "Install the Zafiro.Avalonia NuGet package. Reference the namespace in your XAML with xmlns:zafiro='using:Zafiro.Avalonia' or similar based on your project structure."
      },
      {
        "question": "When should I use Behaviors instead of code-behind?",
        "answer": "Use Interaction.Behaviors for reusable UI logic like focus management or animations. This keeps XAML clean and allows independent testing of UI behaviors."
      },
      {
        "question": "What is the benefit of semantic containers?",
        "answer": "Semantic containers like HeaderedContainer express intent clearly, reduce XAML verbosity, and provide built-in styling hooks via Classes for consistent theming."
      },
      {
        "question": "How do I switch between light and dark themes?",
        "answer": "Define colors and brushes as DynamicResource in Colors.axaml. Reference them in styles. Swap resource dictionaries at runtime to switch themes without rebuilding views."
      },
      {
        "question": "Can I use this skill with existing Avalonia projects?",
        "answer": "Yes. The guidelines apply to any Avalonia project. You can incrementally adopt Zafiro components and shared style patterns as you refactor existing views."
      }
    ]
