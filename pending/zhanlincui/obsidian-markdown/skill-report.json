      {
        "question": "What is Obsidian Flavored Markdown?",
        "answer": "Obsidian Flavored Markdown extends standard Markdown with features like wikilinks, callouts, embeds, and frontmatter properties for note metadata."
      },
      {
        "question": "What is the difference between wikilinks and Markdown links?",
        "answer": "Wikilinks use double brackets [[Note Name]] and automatically create links to notes. Markdown links use [text](url) syntax and require full file paths or URLs."
      },
      {
        "question": "How do I link to a specific heading in another note?",
        "answer": "Use wikilink syntax with # symbol: [[Note Name#Heading]]. The heading must exist in the target note."
      },
      {
        "question": "What are Obsidian properties?",
        "answer": "Properties are YAML key-value pairs at the top of a note (frontmatter) that add metadata like tags, dates, aliases, and custom fields."
      },
      {
        "question": "Can I embed entire notes or just parts?",
        "answer": "You can embed full notes with ![[Note Name]], specific headings with ![[Note Name#Heading]], or specific blocks with ![[Note Name#^block-id]]."
      },
      {
        "question": "What callout types does Obsidian support?",
        "answer": "Obsidian supports: note, abstract, info, todo, tip, success, question, warning, failure, danger, bug, example, and quote."
      }
