  "content": {
    "user_title": "Create and Edit PowerPoint Presentations",
    "value_statement": "This skill enables AI assistants to create, edit, and analyze PowerPoint presentations by converting HTML to slides, manipulating OOXML directly, and using Python automation scripts for batch operations.",
    "seo_keywords": [
      "PowerPoint",
      "pptx",
      "presentation",
      "slides",
      "Office",
      "Claude",
      "Codex",
      "Claude Code",
      "html2pptx",
      "OOXML"
    ],
    "actual_capabilities": [
      "Create new PowerPoint presentations from HTML using html2pptx library",
      "Extract and analyze existing presentation content using markitdown",
      "Manipulate raw OOXML to edit slides, layouts, and metadata",
      "Reorder, duplicate, and delete slides using rearrange.py",
      "Generate thumbnail grids for visual slide analysis",
      "Extract speaker notes and comments from presentations"
    ],
    "limitations": [
      "Cannot edit existing presentation content directly - requires OOXML manipulation",
      "Chart and table editing requires HTML conversion workflow",
      "Design elements limited to web-safe fonts",
      "Complex animations not supported through HTML conversion"
    ],
    "use_cases": [
      {
        "title": "Create presentations from content outlines",
        "description": "Generate professional PowerPoint slides by converting HTML with design-aware color palettes and layout choices",
        "target_user": "Business professionals needing quick presentation creation"
      },
      {
        "title": "Analyze and reorganize existing slides",
        "description": "Extract content from templates, reorder slides, and create new arrangements for repurposing presentations",
        "target_user": "Marketing teams managing presentation libraries"
      },
      {
        "title": "Extract content for documentation",
        "description": "Convert slides to markdown for documentation, extract speaker notes, and analyze slide content at scale",
        "target_user": "Technical writers and content managers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create new presentation",
        "prompt": "Create a new PowerPoint presentation about [TOPIC] with [NUMBER] slides. Use a professional design with appropriate colors. The content should cover: [KEY_POINTS]",
        "scenario": "Starting a presentation from scratch"
      },
      {
        "title": "Convert HTML to slides",
        "prompt": "Convert these HTML slides to PowerPoint using the html2pptx workflow. Analyze the design requirements first, then create properly positioned slides.",
        "scenario": "HTML to PowerPoint conversion"
      },
      {
        "title": "Edit existing presentation",
        "prompt": "I need to modify an existing PowerPoint at [FILE_PATH]. Please unpack it, show me the structure, and help me make these changes: [CHANGES]",
        "scenario": "Modifying existing presentation content"
      },
      {
        "title": "Reorganize slides",
        "prompt": "Reorder slides in [TEMPLATE_FILE] to this sequence: [SLIDE_INDICES]. Use the rearrange.py script to create a new file with slides in that order.",
        "scenario": "Reordering presentation slides"
      }
    ],
    "output_examples": [
      {
        "input": "Create a 5-slide presentation about AI trends",
        "output": [
          "Slide 1: Title slide - 'AI Trends 2024' with bold typography",
          "Slide 2: Two-column layout - Key statistics on left, chart placeholder on right",
          "Slide 3: Full-width content - Bulleted list of major trends",
          "Slide 4: Image placeholder with caption area",
          "Slide 5: Summary with contact information"
        ]
      },
      {
        "input": "Analyze the structure of this presentation",
        "output": [
          "Total slides: 12",
          "Layouts used: Title (1), Title+Content (8), Two Content (3)",
          "Speaker notes: 5 slides have notes",
          "Hidden slides: slides 3, 7",
          "Media files: 8 images embedded"
        ]
      }
    ],
    "best_practices": [
      "Always analyze content first to choose appropriate design elements and color palettes",
      "Use HTML conversion workflow for complex layouts with accurate positioning",
      "Use OOXML manipulation for simple edits like reordering or duplicating slides",
      "Test presentations visually before final delivery"
    ],
    "anti_patterns": [
      "Do not assume all PowerPoint features work through HTML conversion",
      "Avoid creating presentations without first understanding the content structure",
      "Do not skip dimension validation when using html2pptx",
      "Avoid manually editing XML without understanding OOXML relationships"
    ],
    "faq": [
      {
        "question": "How do I create a new PowerPoint from scratch?",
        "answer": "Use the html2pptx workflow: create HTML slides with proper dimensions (13.333x7.5 for 16:9), then use the html2pptx.js library to convert them to PowerPoint with accurate positioning."
      },
      {
        "question": "Can I edit text in an existing presentation?",
        "answer": "Not directly. You need to unpack the .pptx file, edit the raw XML in ppt/slides/slideN.xml, then repack it. The skill provides scripts for this workflow."
      },
      {
        "question": "How do I reorder slides in a template?",
        "answer": "Use the scripts/rearrange.py script with a sequence of slide indices. For example: python scripts/rearrange.py template.pptx output.pptx 0 2 4 1 3"
      },
      {
        "question": "What fonts can I use in presentations?",
        "answer": "Stick to web-safe fonts: Arial, Helvetica, Times New Roman, Georgia, Courier New, Verdana, Tahoma, Trebuchet MS, and Impact."
      },
      {
        "question": "How do I extract content from a presentation?",
        "answer": "Use 'python -m markitdown path-to-file.pptx' to convert the presentation to markdown. For deeper analysis, unpack and examine the XML directly."
      },
      {
        "question": "How do I add speaker notes to slides?",
        "answer": "Unpack the presentation, find or create ppt/notesSlides/notesSlideN.xml files, add your notes in the XML, then repack the presentation."
      }
    ]
  },
