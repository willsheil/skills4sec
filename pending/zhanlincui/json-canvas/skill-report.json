      "Claude Code",
      "Obsidian canvas",
      "JSON canvas",
      "canvas file",
      "mind map",
      "flowchart",
      "visual notes",
      "node graph"
    ],
    "actual_capabilities": [
      "Create new JSON Canvas files with proper structure",
      "Add text, file, link, and group nodes with correct attributes",
      "Define edges connecting nodes with labels and colors",
      "Generate valid hexadecimal IDs for nodes and edges",
      "Build mind maps, flowcharts, and visual diagrams",
      "Validate canvas JSON against JSON Canvas Spec 1.0"
    ],
    "limitations": [
      "Does not interact with Obsidian application directly",
      "Cannot read existing canvas files from filesystem",
      "Does not support custom node types beyond text, file, link, group",
      "No automatic layout or positioning algorithms"
    ],
    "use_cases": [
      {
        "title": "Create Mind Maps",
        "description": "Build visual mind maps for project planning, note organization, or brainstorming sessions with connected nodes",
        "target_user": "Project managers, students, knowledge workers"
      },
      {
        "title": "Design Flowcharts",
        "description": "Create flowcharts and process diagrams with decision nodes, directional edges, and color-coded elements",
        "target_user": "Developers, technical writers, process designers"
      },
      {
        "title": "Organize Research",
        "description": "Connect PDF references, notes, and external links in a visual research canvas for literature review",
        "target_user": "Researchers, academics, analysts"
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple Text Canvas",
        "prompt": "Create a JSON Canvas file with 3 text nodes: a title at the top, and two child nodes below it connected to the title with edges labeled 'Branch A' and 'Branch B'. Use reasonable x, y coordinates and sizes.",
        "scenario": "Creating a basic visual structure"
      },
      {
        "title": "Research Reference Canvas",
        "prompt": "Create a JSON Canvas file with a central text node containing 'Research Topic', connected to 3 file nodes pointing to 'Paper1.pdf', 'Paper2.pdf', 'Paper3.pdf', and one link node pointing to 'https://example.com'. Add edges with labels showing relationships.",
        "scenario": "Building a research reference diagram"
      },
      {
        "title": "Multi-Step Process",
        "prompt": "Create a flowchart canvas with 5 nodes: Start, Step 1, Decision (Yes/No), Step 2, End. Connect them with directional edges. Use colors to distinguish decision points.",
        "scenario": "Designing a process flow"
      },
      {
        "title": "Grouped Organization",
        "prompt": "Create a JSON Canvas with 2 group nodes: 'Group A' containing 2 text nodes, and 'Group B' containing 2 text nodes. Add edges connecting nodes across groups.",
        "scenario": "Organizing related content in containers"
      }
    ],
    "output_examples": [
      {
        "input": "Create a canvas with a central node 'Main Idea' connected to two child nodes",
        "output": [
          "A JSON Canvas file with nodes array containing 3 text nodes positioned appropriately, and edges array connecting center to children with labels"
        ]
      },
      {
        "input": "Build a simple flowchart with start, decision, and end nodes",
        "output": [
          "JSON structure with text nodes colored by type (green for start/end, yellow for decision), connected by directed edges showing flow direction"
        ]
      }
    ],
    "best_practices": [
      "Always include unique hexadecimal IDs for every node and edge",
      "Use color attributes to visually distinguish node types",
      "Order nodes by z-index (first in array = bottom layer)",
      "Define edge labels to clarify relationships between nodes"
    ],
    "anti_patterns": [
      "Forgetting to include the 'nodes' or 'edges' array wrapper",
      "Using duplicate IDs across multiple nodes or edges",
      "Omitting required attributes like 'type', 'x', 'y', 'width', 'height'",
      "Creating self-referencing edges that connect a node to itself"
    ],
    "faq": [
      {
        "question": "What is JSON Canvas?",
        "answer": "JSON Canvas is an open file format for infinite canvas data used in Obsidian. Files use .canvas extension and contain valid JSON with nodes and edges arrays."
      },
      {
        "question": "How do I generate unique IDs?",
        "answer": "Use 16-character hexadecimal strings. Obsidian generates random IDs, but any unique string works for custom canvases."
      },
      {
        "question": "Can I add images to canvas nodes?",
        "answer": "Yes, use file nodes with the 'file' attribute pointing to image paths. The 'subpath' attribute can link to specific sections."
      },
      {
        "question": "What node types are supported?",
        "answer": "Four types: text (Markdown content), file (references), link (external URLs), and group (visual containers)."
      },
      {
        "question": "How do I control visual layering?",
        "answer": "Node order in the array determines z-index. Earlier nodes appear below later nodes. Reorder the array to change layering."
      },
      {
        "question": "Can I create colored edges?",
        "answer": "Yes, add a 'color' attribute to edge objects using the same color system as nodes (0-8 range)."
      }
    ]
